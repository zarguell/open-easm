POSTGRES_DB=easm
POSTGRES_USER=easm
POSTGRES_PASSWORD=easm
EASM_DATABASE_DSN=postgresql://easm:easm@postgres:5432/easm
EASM_CONFIG_PATH=/app/config.yaml
